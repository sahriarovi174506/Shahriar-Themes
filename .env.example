# Frontend Environment Variables
# Create a copy of this file named .env and fill in the values.

# URL of your deployed Vercel serverless backend.
# During development you can use http://localhost:3000 if running vercel dev locally.
VITE_API_URL=https://shahriar-themes-marketplace.vercel.app

# Serverless API (Resend) Environment Variables
# Used by `api/contact.js` on the server (do not expose in the client).
RESEND_API_KEY=re_your_resend_api_key

# Verified sender address in Resend (must be verified in Resend).
RESEND_FROM_EMAIL=you@yourdomain.com

# Where contact-form submissions should be delivered.
RESEND_TO_EMAIL=you@yourdomain.com

# Vercel KV (download counters / stats)
# Used by `api/downloads/[id].js` and `api/stats.js`.
KV_REST_API_URL=https://your-kv-url
KV_REST_API_TOKEN=your-kv-token
